<section class="hero" id="inicio">
  <div class="hero__pattern" aria-hidden="true"></div>

  <div class="hero__content container reveal">
    <a href="<%= routes.HOME %>" class="hero__logo-link" aria-label="<%= appName %>">
      <img
        src="<%= site.logoUrl %>"
        alt="<%= appName %>"
        class="hero__logo"
        width="320"
        height="260"
        decoding="async"
        fetchpriority="high"
      >
    </a>

    <p class="hero__eyebrow"><%= site.tagline %></p>

    <h1 class="hero__title">
      Sabores que<br><span class="hero__title-accent">abrazan</span> el alma
    </h1>

    <p class="hero__subtitle">
      Cocina casera premium, ingredientes seleccionados y el cariño de siempre en cada plato.
    </p>

    <hr class="hero__divider" aria-hidden="true">

    <div class="hero__actions">
      <a href="<%= routes.MENU %>" class="btn btn--primary btn--lg hero__cta">Ver menú</a>
      <% if (whatsapp && whatsapp.phone) { %>
      <a
        href="<%= whatsappUrl %>"
        class="btn btn--outline btn--lg hero__cta hero__cta--whatsapp"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="btn__icon btn__icon--whatsapp" viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
          <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir por WhatsApp
      </a>
      <% } %>
    </div>
  </div>
</section>

<section class="section section--menu" id="menu-destacado">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Nuestra carta</span>
      <h2 class="section__title">Platos destacados</h2>
      <p class="section__subtitle">
        Los favoritos de la casa, preparados al momento con recetas de autor.
      </p>
    </header>

    <% if (featuredItems.length === 0) { %>
    <p class="text-center text-muted">Próximamente nuevos platos en carta.</p>
    <% } else { %>
    <div class="food-grid">
      <% featuredItems.forEach(function(item) { %>
        <%- include('../partials/food-card', { item: item }) %>
      <% }); %>
    </div>
    <% } %>

    <div class="section__cta reveal">
      <a href="<%= routes.MENU %>" class="btn btn--ghost">Explorar menú completo</a>
    </div>
  </div>
</section>

<% if (promotions.length > 0) { %>
<section class="section section--promos" id="promociones">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Ofertas</span>
      <h2 class="section__title">Promociones</h2>
      <p class="section__subtitle">Aprovechá nuestras propuestas especiales de la semana.</p>
    </header>

    <div class="promo-grid">
      <% promotions.forEach(function(promo, index) { %>
      <article class="promo-card reveal<%= index === 0 ? ' promo-card--featured' : '' %>">
        <div class="promo-card__media">
          <img src="<%= promo.image %>" alt="<%= promo.title %>" loading="lazy" class="promo-card__image">
          <div class="promo-card__overlay"></div>
          <span class="promo-card__tag"><%= promo.tag %></span>
        </div>
        <div class="promo-card__body">
          <h3 class="promo-card__title"><%= promo.title %></h3>
          <p class="promo-card__text"><%= promo.description %></p>
          <% if (whatsapp && whatsapp.phone) { %>
          <a
            href="https://wa.me/<%= whatsapp.phone %>?text=<%= encodeURIComponent('Hola! Quiero consultar por: ' + promo.title) %>"
            class="btn btn--primary btn--sm"
            target="_blank"
            rel="noopener noreferrer"
          >
            Consultar promo
          </a>
          <% } %>
        </div>
      </article>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
