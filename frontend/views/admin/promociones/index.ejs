<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
  <div>
    <h1 class="h3 mb-1">Promociones</h1>
    <p class="text-muted mb-0">Gestioná las ofertas visibles en la página principal</p>
  </div>
  <a href="<%= adminRoutes.PROMOCIONES_CREATE %>" class="btn btn-primary">
    <i class="bi bi-plus-lg me-1"></i>Nueva promoción
  </a>
</div>

<div class="card admin-table-card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">#</th>
          <th scope="col">Imagen</th>
          <th scope="col">Nombre</th>
          <th scope="col">Precio</th>
          <th scope="col">Vigencia</th>
          <th scope="col">En home</th>
          <th scope="col">Estado</th>
          <th scope="col" class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (promociones.length === 0) { %>
        <tr>
          <td colspan="8" class="text-center text-muted py-5">No hay promociones registradas</td>
        </tr>
        <% } %>
        <% promociones.forEach(function(promocion) { %>
        <tr>
          <td><%= promocion.id %></td>
          <td>
            <img
              src="<%= promocion.imagenUrl %>"
              alt="<%= promocion.nombre %>"
              class="rounded admin-product-thumb"
              width="48"
              height="48"
              loading="lazy"
              onerror="this.onerror=null;this.src='<%= defaultPromocionImage %>';"
            >
          </td>
          <td>
            <span class="fw-semibold"><%= promocion.nombre %></span>
            <% if (promocion.destacado) { %>
            <span class="badge text-bg-dark ms-1">Destacada</span>
            <% } %>
          </td>
          <td>
            <% if (promocion.precio_promocional != null) { %>
            $<%= Number(promocion.precio_promocional).toLocaleString('es-AR') %>
            <% } else { %>
            —
            <% } %>
          </td>
          <td class="small text-muted">
            <% if (promocion.fecha_inicio_display || promocion.fecha_fin_display) { %>
            <%= promocion.fecha_inicio_display || 'Sin inicio' %>
            —
            <%= promocion.fecha_fin_display || 'Sin fin' %>
            <% } else { %>
            Permanente
            <% } %>
          </td>
          <td>
            <% if (promocion.vigencia.visibleEnHome) { %>
            <span class="badge text-bg-success">Visible</span>
            <% } else if (promocion.vigencia.estado === 'expirada') { %>
            <span class="badge text-bg-danger">Expirada</span>
            <% } else if (promocion.vigencia.estado === 'programada') { %>
            <span class="badge text-bg-info text-dark">Programada</span>
            <% } else { %>
            <span class="badge text-bg-secondary">Oculta</span>
            <% } %>
          </td>
          <td>
            <% if (promocion.activo) { %>
            <span class="badge text-bg-success">Activa</span>
            <% } else { %>
            <span class="badge text-bg-secondary">Inactiva</span>
            <% } %>
          </td>
          <td class="text-end text-nowrap">
            <a href="/admin/promociones/<%= promocion.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar">
              <i class="bi bi-pencil"></i>
            </a>
            <form action="/admin/promociones/<%= promocion.id %>/toggle-destacado" method="post" class="d-inline">

            <%- include('../../partials/csrf-field') %>
              <button
                type="submit"
                class="btn btn-sm btn-outline-<%= promocion.destacado ? 'dark' : 'secondary' %>"
                title="<%= promocion.destacado ? 'Quitar destacada' : 'Marcar destacada' %>"
              >
                <i class="bi bi-star<%= promocion.destacado ? '-fill' : '' %>"></i>
              </button>
            </form>
            <form action="/admin/promociones/<%= promocion.id %>/<%= promocion.activo ? 'desactivar' : 'activar' %>" method="post" class="d-inline">

            <%- include('../../partials/csrf-field') %>
              <button type="submit" class="btn btn-sm btn-outline-<%= promocion.activo ? 'warning' : 'success' %>" title="<%= promocion.activo ? 'Desactivar' : 'Activar' %>">
                <i class="bi bi-<%= promocion.activo ? 'pause' : 'play' %>-fill"></i>
              </button>
            </form>
            <form action="/admin/promociones/<%= promocion.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar esta promoción?');">

            <%- include('../../partials/csrf-field') %>
              <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<p class="small text-muted mt-3 mb-0">
  <i class="bi bi-info-circle me-1"></i>
  Solo se muestran en la home las promociones <strong>activas</strong> y dentro de su rango de fechas.
  Destacada solo cambia el diseño, no la visibilidad.
</p>
