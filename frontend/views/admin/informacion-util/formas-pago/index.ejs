<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="<%= adminRoutes.INFORMACION_UTIL %>">Información útil</a></li>
        <li class="breadcrumb-item active">Formas de pago</li>
      </ol>
    </nav>
    <h1 class="h3 mb-1">Formas de pago</h1>
    <p class="text-muted mb-0">Medios de pago aceptados en el negocio</p>
  </div>
  <a href="<%= adminRoutes.FORMAS_PAGO_CREATE %>" class="btn btn-primary">
    <i class="bi bi-plus-lg me-1"></i>Nueva forma de pago
  </a>
</div>

<div class="card admin-table-card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">Orden</th>
          <th scope="col">#</th>
          <th scope="col">Nombre</th>
          <th scope="col">Descripción</th>
          <th scope="col">Estado</th>
          <th scope="col" class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (formasPago.length === 0) { %>
        <tr>
          <td colspan="6" class="text-center text-muted py-5">No hay formas de pago registradas</td>
        </tr>
        <% } %>
        <% formasPago.forEach(function(formaPago) { %>
        <tr>
          <td class="text-muted"><%= formaPago.orden != null ? formaPago.orden : '—' %></td>
          <td><%= formaPago.id %></td>
          <td class="fw-semibold"><%= formaPago.nombre %></td>
          <td class="small text-muted" style="max-width: 280px;">
            <%= formaPago.descripcion ? (formaPago.descripcion.length > 90 ? formaPago.descripcion.slice(0, 90) + '…' : formaPago.descripcion) : '—' %>
          </td>
          <td>
            <% if (formaPago.activo) { %>
            <span class="badge text-bg-success">Activa</span>
            <% } else { %>
            <span class="badge text-bg-secondary">Inactiva</span>
            <% } %>
          </td>
          <td class="text-end">
            <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
              <% if (formaPago.activo) { %>
              <form action="<%= adminRoutes.FORMAS_PAGO %>/<%= formaPago.id %>/desactivar" method="post" class="d-inline">
                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Desactivar"><i class="bi bi-eye-slash"></i></button>
              </form>
              <% } else { %>
              <form action="<%= adminRoutes.FORMAS_PAGO %>/<%= formaPago.id %>/activar" method="post" class="d-inline">
                <button type="submit" class="btn btn-sm btn-outline-success" title="Activar"><i class="bi bi-eye"></i></button>
              </form>
              <% } %>
              <a href="<%= adminRoutes.FORMAS_PAGO %>/<%= formaPago.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar"><i class="bi bi-pencil"></i></a>
              <form action="<%= adminRoutes.FORMAS_PAGO %>/<%= formaPago.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar esta forma de pago?');">
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar"><i class="bi bi-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
