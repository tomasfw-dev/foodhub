<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="<%= adminRoutes.INFORMACION_UTIL %>">Información útil</a></li>
        <li class="breadcrumb-item active">Zonas de entrega</li>
      </ol>
    </nav>
    <h1 class="h3 mb-1">Zonas de entrega</h1>
    <p class="text-muted mb-0">Barrios y costos de envío visibles para los clientes</p>
  </div>
  <a href="<%= adminRoutes.ZONAS_ENTREGA_CREATE %>" class="btn btn-primary">
    <i class="bi bi-plus-lg me-1"></i>Nueva zona
  </a>
</div>

<div class="card admin-table-card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">Orden</th>
          <th scope="col">#</th>
          <th scope="col">Zona</th>
          <th scope="col">Descripción</th>
          <th scope="col">Costo envío</th>
          <th scope="col">Estado</th>
          <th scope="col" class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (zonas.length === 0) { %>
        <tr>
          <td colspan="7" class="text-center text-muted py-5">No hay zonas registradas</td>
        </tr>
        <% } %>
        <% zonas.forEach(function(zona) { %>
        <tr>
          <td class="text-muted"><%= zona.orden != null ? zona.orden : '—' %></td>
          <td><%= zona.id %></td>
          <td class="fw-semibold"><%= zona.nombre_zona %></td>
          <td class="small text-muted" style="max-width: 240px;">
            <%= zona.descripcion ? (zona.descripcion.length > 80 ? zona.descripcion.slice(0, 80) + '…' : zona.descripcion) : '—' %>
          </td>
          <td>$<%= Number(zona.costo_envio).toLocaleString('es-AR') %></td>
          <td>
            <% if (zona.activo) { %>
            <span class="badge text-bg-success">Activa</span>
            <% } else { %>
            <span class="badge text-bg-secondary">Inactiva</span>
            <% } %>
          </td>
          <td class="text-end">
            <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
              <% if (zona.activo) { %>
              <form action="<%= adminRoutes.ZONAS_ENTREGA %>/<%= zona.id %>/desactivar" method="post" class="d-inline">

              <%- include('../../../partials/csrf-field') %>
                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Desactivar"><i class="bi bi-eye-slash"></i></button>
              </form>
              <% } else { %>
              <form action="<%= adminRoutes.ZONAS_ENTREGA %>/<%= zona.id %>/activar" method="post" class="d-inline">

              <%- include('../../../partials/csrf-field') %>
                <button type="submit" class="btn btn-sm btn-outline-success" title="Activar"><i class="bi bi-eye"></i></button>
              </form>
              <% } %>
              <a href="<%= adminRoutes.ZONAS_ENTREGA %>/<%= zona.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar"><i class="bi bi-pencil"></i></a>
              <form action="<%= adminRoutes.ZONAS_ENTREGA %>/<%= zona.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar esta zona?');">

              <%- include('../../../partials/csrf-field') %>
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar"><i class="bi bi-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
