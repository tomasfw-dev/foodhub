<div class="mb-4">
  <h1 class="h3 mb-1">Hero de la home</h1>
  <p class="text-muted mb-0">
    Editá la sección principal de la landing sin tocar código.
    <% if (hero.fecha_modificacion) { %>
    <span class="d-block small mt-1">
      Última modificación:
      <%= new Date(hero.fecha_modificacion).toLocaleString('es-AR', { dateStyle: 'short', timeStyle: 'short' }) %>
    </span>
    <% } %>
  </p>
</div>

<div class="card admin-form-card">
  <div class="card-body p-4">
    <form action="<%= adminRoutes.HERO %>" method="post" enctype="multipart/form-data">

    <%- include('../../partials/csrf-field') %>
      <%- include('../../partials/admin/hero-form', { hero: hero }) %>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        <a href="<%= routes.HOME %>" class="btn btn-outline-secondary" target="_blank" rel="noopener">
          Ver landing
        </a>
        <a href="<%= adminRoutes.DASHBOARD %>" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
