<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
  <div>
    <h1 class="h3 mb-1">Categorías</h1>
    <p class="text-muted mb-0">Gestioná las categorías del menú</p>
  </div>
  <a href="<%= adminRoutes.CATEGORIAS_CREATE %>" class="btn btn-primary">
    <i class="bi bi-plus-lg me-1"></i>Nueva categoría
  </a>
</div>

<div class="card admin-table-card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">Orden</th>
          <th scope="col">#</th>
          <th scope="col">Nombre</th>
          <th scope="col">Descripción</th>
          <th scope="col">Estado</th>
          <th scope="col" class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (categorias.length === 0) { %>
        <tr>
          <td colspan="6" class="text-center text-muted py-5">No hay categorías registradas</td>
        </tr>
        <% } %>
        <% categorias.forEach(function(categoria) { %>
        <tr>
          <td class="text-muted"><%= categoria.orden != null ? categoria.orden : '—' %></td>
          <td><%= categoria.id %></td>
          <td class="fw-semibold"><%= categoria.nombre %></td>
          <td class="text-muted small"><%= categoria.descripcion || '—' %></td>
          <td>
            <% if (categoria.activo) { %>
            <span class="badge text-bg-success">Activa</span>
            <% } else { %>
            <span class="badge text-bg-secondary">Inactiva</span>
            <% } %>
          </td>
          <td class="text-end">
            <a href="/admin/categorias/<%= categoria.id %>/edit" class="btn btn-sm btn-outline-secondary">
              <i class="bi bi-pencil"></i>
            </a>
            <form action="/admin/categorias/<%= categoria.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar esta categoría?');">
              <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<p class="small text-muted mt-3 mb-0">
  <i class="bi bi-info-circle me-1"></i>
  El <strong>orden</strong> define la posición en el menú público (menor = primero). Sin valor = al final.
</p>
