<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
  <div>
    <h1 class="h3 mb-1">Testimonios</h1>
    <p class="text-muted mb-0">Opiniones de clientes visibles en la página principal</p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <a href="<%= adminRoutes.TESTIMONIOS_PENDIENTES %>" class="btn btn-outline-primary position-relative">
      <i class="bi bi-hourglass-split me-1"></i>Testimonios pendientes
      <% if (typeof pendientesCount !== 'undefined' && pendientesCount > 0) { %>
      <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-danger">
        <%= pendientesCount %>
      </span>
      <% } %>
    </a>
    <a href="<%= adminRoutes.TESTIMONIOS_CREATE %>" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i>Nuevo testimonio
    </a>
  </div>
</div>

<div class="card admin-table-card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">Orden</th>
          <th scope="col">#</th>
          <th scope="col">Cliente</th>
          <th scope="col">Comentario</th>
          <th scope="col">Puntuación</th>
          <th scope="col">Estado</th>
          <th scope="col" class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (testimonios.length === 0) { %>
        <tr>
          <td colspan="7" class="text-center text-muted py-5">No hay testimonios registrados</td>
        </tr>
        <% } %>
        <% testimonios.forEach(function(testimonio) { %>
        <tr>
          <td class="text-muted"><%= testimonio.orden != null ? testimonio.orden : '—' %></td>
          <td><%= testimonio.id %></td>
          <td class="fw-semibold"><%= testimonio.nombre_cliente %></td>
          <td class="small text-muted" style="max-width: 280px;">
            <%= testimonio.comentario.length > 90 ? testimonio.comentario.slice(0, 90) + '…' : testimonio.comentario %>
          </td>
          <td>
            <span class="text-nowrap" aria-label="<%= testimonio.puntuacion %> de 5 estrellas">
              <% for (let i = 1; i <= 5; i += 1) { %>
              <i class="bi bi-star<%= i <= testimonio.puntuacion ? '-fill text-warning' : ' text-muted' %>"></i>
              <% } %>
            </span>
          </td>
          <td>
            <% if (testimonio.estado === 'rechazado') { %>
            <span class="badge text-bg-danger">Rechazado</span>
            <% } else if (testimonio.activo) { %>
            <span class="badge text-bg-success">Activo</span>
            <% } else { %>
            <span class="badge text-bg-secondary">Inactivo</span>
            <% } %>
          </td>
          <td class="text-end">
            <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
              <% if (testimonio.activo) { %>
              <form action="<%= adminRoutes.TESTIMONIOS %>/<%= testimonio.id %>/desactivar" method="post" class="d-inline">

              <%- include('../../partials/csrf-field') %>
                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Desactivar">
                  <i class="bi bi-eye-slash"></i>
                </button>
              </form>
              <% } else { %>
              <form action="<%= adminRoutes.TESTIMONIOS %>/<%= testimonio.id %>/activar" method="post" class="d-inline">

              <%- include('../../partials/csrf-field') %>
                <button type="submit" class="btn btn-sm btn-outline-success" title="Activar">
                  <i class="bi bi-eye"></i>
                </button>
              </form>
              <% } %>
              <a href="<%= adminRoutes.TESTIMONIOS %>/<%= testimonio.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar">
                <i class="bi bi-pencil"></i>
              </a>
              <form action="<%= adminRoutes.TESTIMONIOS %>/<%= testimonio.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar este testimonio?');">

              <%- include('../../partials/csrf-field') %>
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<p class="small text-muted mt-3 mb-0">
  <i class="bi bi-info-circle me-1"></i>
  Solo los testimonios <strong>aprobados y activos</strong> se muestran en la home. Los envíos desde la web quedan en
  <a href="<%= adminRoutes.TESTIMONIOS_PENDIENTES %>">Testimonios pendientes</a> hasta ser moderados.
</p>
