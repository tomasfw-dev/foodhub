<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="<%= adminRoutes.TESTIMONIOS %>">Testimonios</a></li>
        <li class="breadcrumb-item active" aria-current="page">Pendientes</li>
      </ol>
    </nav>
    <h1 class="h3 mb-1">Testimonios pendientes</h1>
    <p class="text-muted mb-0">Opiniones enviadas desde la web que esperan moderación</p>
  </div>
  <a href="<%= adminRoutes.TESTIMONIOS %>" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Volver al listado
  </a>
</div>

<div class="card admin-table-card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">#</th>
          <th scope="col">Cliente</th>
          <th scope="col">Comentario</th>
          <th scope="col">Puntuación</th>
          <th scope="col">Recibido</th>
          <th scope="col" class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (testimonios.length === 0) { %>
        <tr>
          <td colspan="6" class="text-center text-muted py-5">No hay testimonios pendientes de revisión</td>
        </tr>
        <% } %>
        <% testimonios.forEach(function(testimonio) { %>
        <tr>
          <td><%= testimonio.id %></td>
          <td class="fw-semibold"><%= testimonio.nombre_cliente %></td>
          <td class="small text-muted" style="max-width: 320px;">
            <%= testimonio.comentario.length > 100 ? testimonio.comentario.slice(0, 100) + '…' : testimonio.comentario %>
          </td>
          <td>
            <span class="text-nowrap" aria-label="<%= testimonio.puntuacion %> de 5 estrellas">
              <% for (let i = 1; i <= 5; i += 1) { %>
              <i class="bi bi-star<%= i <= testimonio.puntuacion ? '-fill text-warning' : ' text-muted' %>"></i>
              <% } %>
            </span>
          </td>
          <td class="small text-muted text-nowrap">
            <% if (testimonio.fecha_creacion) { %>
            <%= new Date(testimonio.fecha_creacion).toLocaleString('es-AR', { dateStyle: 'short', timeStyle: 'short' }) %>
            <% } else { %>
            —
            <% } %>
          </td>
          <td class="text-end">
            <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
              <a
                href="<%= adminRoutes.TESTIMONIOS_PENDIENTES %>/<%= testimonio.id %>/edit"
                class="btn btn-sm btn-outline-primary"
                title="Revisar y moderar"
              >
                <i class="bi bi-pencil-square"></i>
              </a>
              <form
                action="<%= adminRoutes.TESTIMONIOS_PENDIENTES %>/<%= testimonio.id %>/aprobar"
                method="post"
                class="d-inline"
              >
                <button type="submit" class="btn btn-sm btn-success" title="Aprobar">
                  <i class="bi bi-check-lg"></i>
                </button>
              </form>
              <form
                action="<%= adminRoutes.TESTIMONIOS_PENDIENTES %>/<%= testimonio.id %>/rechazar"
                method="post"
                class="d-inline"
                onsubmit="return confirm('¿Rechazar este testimonio?');"
              >
                <button type="submit" class="btn btn-sm btn-outline-warning" title="Rechazar">
                  <i class="bi bi-x-lg"></i>
                </button>
              </form>
              <form
                action="<%= adminRoutes.TESTIMONIOS_PENDIENTES %>/<%= testimonio.id %>/delete"
                method="post"
                class="d-inline"
                onsubmit="return confirm('¿Eliminar este testimonio?');"
              >
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<p class="small text-muted mt-3 mb-0">
  <i class="bi bi-info-circle me-1"></i>
  Los testimonios aprobados se publican en la home. Los rechazados quedan ocultos y pueden eliminarse.
</p>
