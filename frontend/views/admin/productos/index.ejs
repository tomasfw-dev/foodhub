<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
  <div>
    <h1 class="h3 mb-1">Productos</h1>
    <p class="text-muted mb-0">
      Gestioná el catálogo de comidas
      <span class="d-block small mt-1">
        Destacados en home: <strong><%= totalDestacados %>/<%= maxDestacados %></strong>
      </span>
    </p>
  </div>
  <a href="<%= adminRoutes.PRODUCTOS_CREATE %>" class="btn btn-primary">
    <i class="bi bi-plus-lg me-1"></i>Nuevo producto
  </a>
</div>

<div class="card admin-table-card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">#</th>
          <th scope="col">Imagen</th>
          <th scope="col">Nombre</th>
          <th scope="col">Categoría</th>
          <th scope="col">Precio</th>
          <th scope="col">Estado</th>
          <th scope="col">Home</th>
          <th scope="col" class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (productos.length === 0) { %>
        <tr>
          <td colspan="8" class="text-center text-muted py-5">No hay productos registrados</td>
        </tr>
        <% } %>
        <% productos.forEach(function(producto) { %>
        <tr>
          <td><%= producto.id %></td>
          <td>
            <img
              src="<%= producto.imagenUrl %>"
              alt="<%= producto.nombre %>"
              class="rounded admin-product-thumb"
              width="48"
              height="48"
              loading="lazy"
              onerror="this.onerror=null;this.src='<%= defaultProductImage %>';"
            >
          </td>
          <td>
            <span class="fw-semibold"><%= producto.nombre %></span>
            <% if (producto.destacado) { %>
            <span class="badge text-bg-dark ms-1">
              <i class="bi bi-star-fill me-1"></i>Destacado
            </span>
            <% } %>
          </td>
          <td><%= categoriasMap[producto.categoriaId] || '—' %></td>
          <td>
            <% if (producto.precio != null) { %>
            $<%= Number(producto.precio).toLocaleString('es-AR') %>
            <% } else { %>
            —
            <% } %>
          </td>
          <td>
            <% if (producto.activo) { %>
            <span class="badge text-bg-success">Activo</span>
            <% } else { %>
            <span class="badge text-bg-secondary">Inactivo</span>
            <% } %>
          </td>
          <td>
            <% if (producto.destacado && producto.activo) { %>
            <span class="badge text-bg-success">Visible</span>
            <% } else if (producto.destacado && !producto.activo) { %>
            <span class="badge text-bg-warning text-dark">Inactivo</span>
            <% } else { %>
            <span class="badge text-bg-light text-muted border">—</span>
            <% } %>
          </td>
          <td class="text-end text-nowrap">
            <a href="/admin/productos/<%= producto.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar">
              <i class="bi bi-pencil"></i>
            </a>
            <form action="/admin/productos/<%= producto.id %>/toggle-destacado" method="post" class="d-inline">
              <button
                type="submit"
                class="btn btn-sm btn-outline-<%= producto.destacado ? 'dark' : 'secondary' %>"
                title="<%= producto.destacado ? 'Quitar de destacados' : 'Marcar como destacado' %>"
                <%= !producto.destacado && totalDestacados >= maxDestacados ? 'disabled' : '' %>
              >
                <i class="bi bi-star<%= producto.destacado ? '-fill' : '' %>"></i>
              </button>
            </form>
            <form action="/admin/productos/<%= producto.id %>/<%= producto.activo ? 'desactivar' : 'activar' %>" method="post" class="d-inline">
              <button type="submit" class="btn btn-sm btn-outline-<%= producto.activo ? 'warning' : 'success' %>" title="<%= producto.activo ? 'Desactivar' : 'Activar' %>">
                <i class="bi bi-<%= producto.activo ? 'pause' : 'play' %>-fill"></i>
              </button>
            </form>
            <form action="/admin/productos/<%= producto.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar este producto?');">
              <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<p class="small text-muted mt-3 mb-0">
  <i class="bi bi-info-circle me-1"></i>
  Máximo <strong><%= maxDestacados %> productos destacados</strong> en la home.
  Deben estar <strong>activos</strong> para aparecer en «Nuestras Recomendaciones».
</p>
