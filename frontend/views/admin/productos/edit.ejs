<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="<%= adminRoutes.PRODUCTOS %>">Productos</a></li>
      <li class="breadcrumb-item active" aria-current="page">Editar</li>
    </ol>
  </nav>
  <h1 class="h3 mb-1">Editar producto</h1>
</div>

<div class="card admin-form-card">
  <div class="card-body p-4">
    <form action="/admin/productos/<%= producto.id %>/edit" method="post">
      <%- include('../../partials/admin/producto-form', { producto: producto, categorias: categorias }) %>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a href="<%= adminRoutes.PRODUCTOS %>" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
