<footer class="site-footer" id="contacto">
  <div class="container">
    <div class="site-footer__brand">
      <%- include('./public-brand', {
        brandLinkClass: 'site-footer__logo',
        brandImgClass: 'site-footer__logo-img',
        brandTextClass: 'site-footer__brand-name',
        brandImgWidth: 220,
        brandImgHeight: 220,
        brandImgLoading: 'lazy',
      }) %>
      <p class="site-footer__tagline"><%= site.tagline %></p>
    </div>

    <hr class="site-footer__divider" aria-hidden="true">

    <div class="site-footer__grid">
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Contacto</h3>
        <ul class="site-footer__list">
          <% if (whatsapp && whatsapp.phone) { %>
          <li>
            <a
              href="https://wa.me/<%= whatsapp.phone %>"
              target="_blank"
              rel="noopener noreferrer"
              class="site-footer__link"
            >
              WhatsApp
            </a>
          </li>
          <% } %>
          <% if (site.email) { %>
          <li>
            <a href="mailto:<%= site.email %>" class="site-footer__link"><%= site.email %></a>
          </li>
          <% } %>
          <% if (site.instagram) { %>
          <li>
            <a
              href="<%= site.instagram %>"
              target="_blank"
              rel="noopener noreferrer"
              class="site-footer__link"
            >
              Instagram<% if (site.instagramHandle) { %> · <%= site.instagramHandle %><% } %>
            </a>
          </li>
          <% } %>
        </ul>
      </div>

      <div class="site-footer__col">
        <h3 class="site-footer__heading">Información</h3>
        <ul class="site-footer__list">
          <li>
            <a href="<%= routes.INFORMACION_UTIL %>" class="site-footer__link">Información útil</a>
          </li>
          <li>
            <a href="<%= routes.MENU %>" class="site-footer__link">Menú completo</a>
          </li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h3 class="site-footer__heading">Horarios</h3>
        <p class="site-footer__text"><%= site.hours || 'Consultá por WhatsApp' %></p>
      </div>

      <div class="site-footer__col">
        <h3 class="site-footer__heading">Ubicación</h3>
        <p class="site-footer__text"><%= site.location || 'Consultá por WhatsApp' %></p>
        <p class="site-footer__note">Retiro y envíos por zona — consultá por WhatsApp</p>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>&copy; <%= new Date().getFullYear() %> <%= appName %>. Hecho con amor en casa.</p>
    </div>
  </div>
</footer>
