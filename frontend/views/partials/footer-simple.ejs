<footer class="site-footer site-footer--simple">
  <div class="container">
    <a href="<%= routes.HOME %>" class="site-footer__logo site-footer__logo--simple" aria-label="<%= appName %> — Inicio">
      <img
        src="<%= site.logoUrl %>"
        alt="<%= appName %>"
        class="site-footer__logo-img"
        width="140"
        height="140"
        loading="lazy"
        decoding="async"
      >
    </a>
    <p>&copy; <%= new Date().getFullYear() %> <%= appName %>. Todos los derechos reservados.</p>
  </div>
</footer>
