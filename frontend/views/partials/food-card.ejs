<article class="food-card reveal">
  <div class="food-card__media">
    <img
      src="<%= item.image %>"
      alt="<%= item.name %>"
      class="food-card__image"
      loading="lazy"
      width="400"
      height="300"
      onerror="this.onerror=null;this.src='<%= defaultProductImage %>';"
    >
    <% if (item.badge) { %>
    <span class="food-card__badge"><%= item.badge %></span>
    <% } %>
  </div>

  <div class="food-card__body">
    <h3 class="food-card__title"><%= item.name %></h3>
    <% if (item.description) { %>
    <p class="food-card__description"><%= item.description %></p>
    <% } %>

    <hr class="food-card__divider" aria-hidden="true">

    <div class="food-card__footer">
      <% if (item.price != null) { %>
      <span class="food-card__price">$<%= item.price.toLocaleString('es-AR') %></span>
      <% } %>
      <div class="food-card__actions">
        <%- include('add-to-order-btn', {
          orderKey: 'producto-' + item.id,
          orderType: 'producto',
          orderName: item.name,
          orderPrice: item.price
        }) %>
      </div>
    </div>
  </div>
</article>
