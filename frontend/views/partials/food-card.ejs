<%
  const waText = encodeURIComponent('Hola! Me interesa pedir: ' + item.name);
  const waLink = whatsapp.phone
    ? 'https://wa.me/' + whatsapp.phone + '?text=' + waText
    : 'https://wa.me/?text=' + waText;
%>
<article class="food-card reveal">
  <div class="food-card__media">
    <img
      src="<%= item.image %>"
      alt="<%= item.name %>"
      class="food-card__image"
      loading="lazy"
      width="400"
      height="300"
      onerror="this.onerror=null;this.src='<%= defaultProductImage %>';"
    >
    <% if (item.badge) { %>
    <span class="food-card__badge"><%= item.badge %></span>
    <% } %>
    <div class="food-card__overlay"></div>
  </div>

  <div class="food-card__body">
    <h3 class="food-card__title"><%= item.name %></h3>
    <p class="food-card__description"><%= item.description %></p>
    <div class="food-card__footer">
      <% if (item.price != null) { %>
      <span class="food-card__price">$<%= item.price.toLocaleString('es-AR') %></span>
      <% } %>
      <a
        href="<%= waLink %>"
        class="btn btn--whatsapp btn--sm food-card__cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Pedir
      </a>
    </div>
  </div>
</article>
