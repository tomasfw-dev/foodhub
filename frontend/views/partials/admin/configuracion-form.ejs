<div class="row g-3">
  <div class="col-md-6">
    <label for="nombre_negocio" class="form-label">Nombre del negocio <span class="text-danger">*</span></label>
    <input
      type="text"
      class="form-control"
      id="nombre_negocio"
      name="nombre_negocio"
      value="<%= configuracion.nombre_negocio %>"
      required
      maxlength="120"
    >
  </div>
  <div class="col-md-6">
    <label for="slogan" class="form-label">Slogan <span class="text-danger">*</span></label>
    <input
      type="text"
      class="form-control"
      id="slogan"
      name="slogan"
      value="<%= configuracion.slogan %>"
      required
      maxlength="300"
    >
  </div>

  <div class="col-md-6">
    <label for="email" class="form-label">Email de contacto</label>
    <input
      type="email"
      class="form-control"
      id="email"
      name="email"
      value="<%= configuracion.email %>"
      maxlength="255"
      placeholder="hola@bendita-comida.com"
    >
  </div>
  <div class="col-md-6">
    <label for="telefono" class="form-label">Teléfono</label>
    <input
      type="text"
      class="form-control"
      id="telefono"
      name="telefono"
      value="<%= configuracion.telefono %>"
      maxlength="30"
      placeholder="011 1234-5678"
    >
    <div class="form-text">Solo se guardan números (sin espacios ni guiones).</div>
  </div>

  <div class="col-md-6">
    <label for="whatsapp" class="form-label">WhatsApp</label>
    <input
      type="text"
      class="form-control"
      id="whatsapp"
      name="whatsapp"
      value="<%= configuracion.whatsapp %>"
      maxlength="30"
      placeholder="5491112345678"
    >
    <div class="form-text">Código de país + número, sin símbolos. Ej: 5491112345678</div>
  </div>
  <div class="col-md-6">
    <label for="mensaje_whatsapp" class="form-label">Mensaje predeterminado de WhatsApp</label>
    <input
      type="text"
      class="form-control"
      id="mensaje_whatsapp"
      name="mensaje_whatsapp"
      value="<%= configuracion.mensaje_whatsapp %>"
      maxlength="500"
      placeholder="Hola! Quiero hacer un pedido."
    >
  </div>

  <div class="col-md-6">
    <label for="instagram" class="form-label">Instagram (URL)</label>
    <input
      type="url"
      class="form-control"
      id="instagram"
      name="instagram"
      value="<%= configuracion.instagram %>"
      maxlength="500"
      placeholder="https://instagram.com/tu_cuenta"
    >
  </div>
  <div class="col-md-6">
    <label for="facebook" class="form-label">Facebook (URL)</label>
    <input
      type="url"
      class="form-control"
      id="facebook"
      name="facebook"
      value="<%= configuracion.facebook %>"
      maxlength="500"
      placeholder="https://facebook.com/tu_pagina"
    >
  </div>

  <div class="col-md-6">
    <label for="direccion" class="form-label">Dirección / ubicación</label>
    <input
      type="text"
      class="form-control"
      id="direccion"
      name="direccion"
      value="<%= configuracion.direccion %>"
      maxlength="300"
      placeholder="Buenos Aires, Argentina"
    >
  </div>
  <div class="col-md-6">
    <label for="horarios" class="form-label">Horarios de atención</label>
    <input
      type="text"
      class="form-control"
      id="horarios"
      name="horarios"
      value="<%= configuracion.horarios %>"
      maxlength="200"
      placeholder="Lun – Sáb · 11:00 a 21:00"
    >
  </div>

  <div class="col-12">
    <label for="logo" class="form-label">Logo del negocio</label>
    <% if (configuracion.logoUrl) { %>
    <div class="mb-3">
      <img
        src="<%= configuracion.logoUrl %>"
        alt="Logo actual"
        class="img-thumbnail bg-white"
        style="max-height: 120px; max-width: 240px; object-fit: contain;"
        onerror="this.onerror=null;this.src='/images/logo-bendita-comida.png';"
      >
      <p class="small text-muted mt-1 mb-0">Logo actual. Subí un archivo para reemplazarlo.</p>
    </div>
    <% } %>
    <input
      type="file"
      class="form-control"
      id="logo"
      name="logo"
      accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
    >
    <div class="form-text">
      JPG, JPEG, PNG o WEBP. Máximo 5 MB. Si no subís archivo, se mantiene el logo actual.
    </div>
  </div>

  <div class="col-12">
    <hr class="my-2">
    <h2 class="h6 text-uppercase text-muted mb-3">SEO y redes sociales</h2>
    <p class="small text-muted mb-3">
      Mejoran cómo se ve el sitio en Google y al compartir enlaces por WhatsApp, Facebook e Instagram.
      Si dejás los campos vacíos, se usan el nombre, slogan y logo del negocio.
    </p>
  </div>

  <div class="col-md-6">
    <label for="seo_title" class="form-label">Título SEO</label>
    <input
      type="text"
      class="form-control"
      id="seo_title"
      name="seo_title"
      value="<%= configuracion.seo_title %>"
      maxlength="120"
      placeholder="<%= configuracion.nombre_negocio %> — <%= configuracion.slogan %>"
    >
    <div class="form-text">Recomendado: hasta 60 caracteres. Máximo 120.</div>
  </div>

  <div class="col-md-6">
    <label for="seo_keywords" class="form-label">Palabras clave</label>
    <input
      type="text"
      class="form-control"
      id="seo_keywords"
      name="seo_keywords"
      value="<%= configuracion.seo_keywords %>"
      maxlength="500"
      placeholder="comida casera, menú, delivery"
    >
    <div class="form-text">Separadas por comas. Máximo 500 caracteres.</div>
  </div>

  <div class="col-12">
    <label for="seo_description" class="form-label">Descripción SEO</label>
    <textarea
      class="form-control"
      id="seo_description"
      name="seo_description"
      rows="3"
      maxlength="320"
      placeholder="Breve descripción para buscadores y redes sociales."
    ><%= configuracion.seo_description %></textarea>
    <div class="form-text">Recomendado: hasta 160 caracteres. Máximo 320.</div>
  </div>

  <div class="col-12">
    <label for="og_image" class="form-label">Imagen Open Graph (compartir en redes)</label>
    <% if (configuracion.ogImageUrl) { %>
    <div class="mb-3">
      <img
        src="<%= configuracion.ogImageUrl %>"
        alt="Imagen OG actual"
        class="img-thumbnail bg-white"
        style="max-height: 160px; max-width: 320px; object-fit: cover;"
        onerror="this.onerror=null;this.src='<%= configuracion.logoUrl %>';"
      >
      <p class="small text-muted mt-1 mb-0">
        Imagen actual para previews. Recomendado 1200×630 px. Si no subís archivo, se usa el logo.
      </p>
    </div>
    <% } %>
    <input
      type="file"
      class="form-control"
      id="og_image"
      name="og_image"
      accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
    >
    <div class="form-text">
      JPG, JPEG, PNG o WEBP. Máximo 5 MB. Ideal para WhatsApp y Facebook.
    </div>
  </div>
</div>
