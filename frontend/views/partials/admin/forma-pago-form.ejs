<div class="row g-3">
  <div class="col-md-6">
    <label for="nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
    <input
      type="text"
      class="form-control"
      id="nombre"
      name="nombre"
      value="<%= formaPago ? formaPago.nombre : '' %>"
      required
      maxlength="80"
    >
  </div>

  <div class="col-md-6">
    <label for="orden" class="form-label">Orden</label>
    <input
      type="number"
      class="form-control"
      id="orden"
      name="orden"
      value="<%= formaPago && formaPago.orden != null ? formaPago.orden : '' %>"
      min="0"
      step="1"
      placeholder="Automático"
    >
  </div>

  <div class="col-12">
    <label for="descripcion" class="form-label">Descripción</label>
    <textarea
      class="form-control"
      id="descripcion"
      name="descripcion"
      rows="3"
      maxlength="500"
    ><%= formaPago ? formaPago.descripcion : '' %></textarea>
  </div>

  <div class="col-12">
    <div class="form-check form-switch">
      <input
        class="form-check-input"
        type="checkbox"
        id="activo"
        name="activo"
        <%= !formaPago || formaPago.activo ? 'checked' : '' %>
      >
      <label class="form-check-label" for="activo">Visible en la web</label>
    </div>
  </div>
</div>
