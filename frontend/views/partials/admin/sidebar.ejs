<aside
  class="admin-sidebar offcanvas-lg offcanvas-start"
  tabindex="-1"
  id="adminSidebar"
  aria-labelledby="adminSidebarLabel"
>
  <span id="adminSidebarLabel" class="visually-hidden"><%= platformName %> — Panel administrativo</span>

  <div class="offcanvas-header d-lg-none admin-sidebar__mobile-bar">
    <span class="admin-sidebar__mobile-title">Menú admin</span>
    <button
      type="button"
      class="btn-close"
      data-bs-dismiss="offcanvas"
      data-bs-target="#adminSidebar"
      aria-label="Cerrar menú"
    ></button>
  </div>

  <div class="offcanvas-body admin-sidebar__inner">
    <header class="admin-sidebar__head">
      <a href="<%= adminRoutes.DASHBOARD %>" class="admin-sidebar__logo-link" aria-label="<%= platformName %> — Dashboard">
        <img
          src="<%= platformLogoUrl %>"
          alt="<%= platformName %>"
          class="admin-sidebar__logo"
          width="240"
          height="88"
          decoding="async"
        >
      </a>

      <div class="admin-sidebar__meta">
        <span class="admin-sidebar__badge">Panel administrativo</span>
        <% if (typeof adminUser !== 'undefined' && adminUser) { %>
        <div class="admin-sidebar__user">
          <i class="bi bi-person-circle admin-sidebar__user-icon" aria-hidden="true"></i>
          <span class="admin-sidebar__user-name"><%= adminUser.nombre %></span>
        </div>
        <% } %>
      </div>
    </header>

    <nav class="admin-sidebar__menu" aria-label="Módulos administrativos">
      <%
        const adminMenuItems = [
          { key: 'dashboard', href: adminRoutes.DASHBOARD, icon: 'bi-speedometer2', label: 'Dashboard' },
          { key: 'categorias', href: adminRoutes.CATEGORIAS, icon: 'bi-folder', label: 'Categorías' },
          { key: 'productos', href: adminRoutes.PRODUCTOS, icon: 'bi-basket', label: 'Productos' },
          { key: 'promociones', href: adminRoutes.PROMOCIONES, icon: 'bi-tag', label: 'Promociones' },
          { key: 'hero', href: adminRoutes.HERO, icon: 'bi-image', label: 'Hero home' },
          { key: 'testimonios', href: adminRoutes.TESTIMONIOS, icon: 'bi-chat-quote', label: 'Testimonios' },
          { key: 'informacion-util', href: adminRoutes.INFORMACION_UTIL, icon: 'bi-info-circle', label: 'Información útil' },
          { key: 'configuracion', href: adminRoutes.CONFIGURACION, icon: 'bi-gear', label: 'Configuración' },
          { key: 'perfil', href: adminRoutes.PERFIL, icon: 'bi-person', label: 'Mi perfil' },
        ];
      %>
      <% adminMenuItems.forEach(function(item) { %>
      <a
        href="<%= item.href %>"
        class="admin-sidebar__link<%= activeMenu === item.key ? ' is-active' : '' %>"
      >
        <i class="bi <%= item.icon %> admin-sidebar__link-icon" aria-hidden="true"></i>
        <span class="admin-sidebar__link-text"><%= item.label %></span>
      </a>
      <% }); %>
    </nav>

    <footer class="admin-sidebar__foot">
      <a href="<%= routes.AUTH_LOGOUT %>" class="admin-sidebar__link admin-sidebar__link--danger">
        <i class="bi bi-box-arrow-right admin-sidebar__link-icon" aria-hidden="true"></i>
        <span class="admin-sidebar__link-text">Cerrar sesión</span>
      </a>
      <a
        href="<%= routes.HOME %>"
        class="admin-sidebar__link admin-sidebar__link--muted"
        target="_blank"
        rel="noopener noreferrer"
      >
        <i class="bi bi-globe admin-sidebar__link-icon" aria-hidden="true"></i>
        <span class="admin-sidebar__link-text">Ver sitio</span>
      </a>
    </footer>
  </div>
</aside>
